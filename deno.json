{
  "tasks": {
    "dev": "deno run --allow-net --allow-read --watch dev.ts",
    "serve": "deno run --allow-net --allow-read dev.ts",
    "build": "deno run --allow-read --allow-write --allow-env --allow-net=jsr.io:443 build.ts",
    "test": "deno test src/",
    "lint": "deno lint",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/**/*.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@deno/emit": "jsr:@deno/emit@0.45.0",
    "@std/http/server": "https://deno.land/std@0.224.0/http/server.ts",
    "@std/path": "https://deno.land/std@0.224.0/path/mod.ts"
  },
  "fmt": {
    "exclude": [".ai/", "assets/", ".github/copilot-instructions.md"]
  },
  "lint": {
    "exclude": [".ai/", "assets/"]
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["deno.ns", "dom", "dom.iterable", "dom.asynciterable"]
  }
}
